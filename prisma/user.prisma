model User {
  id   Int    @id @default(autoincrement())
  email     String   @unique
  username String @unique
  password  String
  bio       String?
  image     String?
  refreshToken String?
  articles  Article[]
  comments Comment[]
  favorites Favorite[]
  followers Follow[] @relation("UserFollowers")
  following Follow[] @relation("UserFollowing")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
