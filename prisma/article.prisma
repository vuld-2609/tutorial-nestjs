model Article {
  id        Int      @id @default(autoincrement())
  slug      String   @unique
  title     String
  description String
  body      String @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  authorId  Int
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  tags      Tag[]    @relation("ArticleTags")
}
